{{!-- views/gcal-callback.hbs — Google OAuth callback result page --}}

<section class="page-hero">
  <div class="container page-hero-inner">
    {{#if success}}
      <span class="section-eyebrow">Google Calendar</span>
      <h1>Authorization successful!</h1>
      <p>Copy the code below and paste it into <code>/gcalint verify</code> in your Discord server.</p>
    {{else}}
      <span class="section-eyebrow">Google Calendar</span>
      <h1>Authorization failed</h1>
      <p>Something went wrong during Google authorization. Please try running <code>/gcalint add</code> again.</p>
    {{/if}}
  </div>
</section>

<section class="section--sm section">
  <div class="container gcal-container">

    {{#if success}}
      <div class="callout callout--success reveal">
        <span>✅</span>
        <span><strong>Your authorization code:</strong></span>
      </div>

      <div class="gcal-code-block" id="code-block">{{code}}</div>

      <div class="gcal-copy-wrap">
        <button id="copy-btn" class="gcal-copy-btn" onclick="copyCode()">
          📋 Copy Code
        </button>
      </div>

      <div class="callout callout--info reveal gcal-info-callout">
        <span>📋</span>
        <span>
          Copy the entire code above, then go back to your Discord server and run
          <code>/gcalint verify</code> and paste it in. You can close this tab afterwards.
        </span>
      </div>

    {{else}}
      <div class="callout callout--warning reveal">
        <span>⚠️</span>
        <span>
          <strong>Error:</strong> {{error}}
        </span>
      </div>

      <div class="callout callout--info reveal gcal-error-info">
        <span>💡</span>
        <span>
          Head back to your Discord server and run <code>/gcalint add</code> to start the process again.
          If this keeps happening, reach out in the
          <a href="{{discordServer}}" target="_blank" rel="noopener">Soren support Discord</a>.
        </span>
      </div>
    {{/if}}

    <div class="gcal-back-wrap">
      <a href="/" class="btn btn--secondary">← Back to Soren</a>
    </div>

  </div>
</section>

{{#if success}}
<script>
  function copyCode() {
    const code = document.getElementById("code-block").innerText.trim();
    const btn  = document.getElementById("copy-btn");
    btn.disabled = true;
    btn.innerText = "⏳ Copying…";

    navigator.clipboard.writeText(code).then(() => {
      btn.innerText = "✅ Copied!";
      btn.classList.add("gcal-copy-btn--success");
      setTimeout(() => {
        btn.innerText = "📋 Copy Code";
        btn.classList.remove("gcal-copy-btn--success");
        btn.disabled = false;
      }, 2500);
    }).catch(() => {
      btn.innerText = "❌ Copy failed — select manually";
      btn.disabled = false;
    });
  }
</script>
{{/if}}
