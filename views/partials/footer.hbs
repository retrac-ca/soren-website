<!-- ── Footer Partial ────────────────────────────────────────────────────────
     Included automatically in the main layout.
────────────────────────────────────────────────────────────────────────── -->
<footer class="site-footer">
  <div class="container footer-inner">

    <!-- Brand column -->
    <div class="footer-brand">
      <div class="logo">
        <img src="https://i.postimg.cc/brwRqpwb/Soren-Regular-Logo.jpg" alt="{{botName}}" class="logo-img" />
        <span class="logo-text">{{botName}}</span>
      </div>
      <p class="footer-tagline">{{botTagline}}</p>
      <p class="footer-meta">Made with ☕ by <strong>{{creatorName}}</strong></p>
    </div>

    <!-- Navigation columns -->
    <div class="footer-links">
      <div class="footer-col">
        <h4>Product</h4>
        <a href="/">Home</a>
        <a href="/features">Features</a>
        <a href="/features#pricing">Pricing</a>
      </div>
      <div class="footer-col">
        <h4>Learn</h4>
        <a href="/setup">Getting Started</a>
        <a href="/docs">Documentation</a>
        <a href="/docs#faq">FAQ</a>
      </div>
      <div class="footer-col">
        <h4>Community</h4>
        <a href="{{githubUrl}}" target="_blank" rel="noopener">GitHub</a>
        <a href="{{discordServer}}" target="_blank" rel="noopener">Discord Server</a>
        <a href="{{inviteUrl}}" target="_blank" rel="noopener">Add to Server</a>
      </div>
      <div class="footer-col">
        <h4>Legal</h4>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="mailto:info@retrac.ca">Contact Us</a>
      </div>
    </div>

  </div>

  <!-- Footer bottom bar -->
  <div class="footer-bottom">
    <div class="container">
      <span>© 2024–2026 {{botName}} · v{{botVersion}} · MIT License</span>
      <span class="footer-bottom-right">
        <a href="/privacy">Privacy Policy</a>
        &nbsp;·&nbsp;
        <a href="/terms">Terms of Service</a>
        &nbsp;·&nbsp;
        <a href="{{githubUrl}}" target="_blank" rel="noopener">Open Source on GitHub</a>
      </span>
    </div>
  </div>
</footer>