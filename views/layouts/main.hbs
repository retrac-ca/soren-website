<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{botDescription}}" />
  <title>{{title}}</title>

  <!-- ── Fonts ────────────────────────────────────────────────────────── -->
  <!-- Syne: geometric, modern display font for headings -->
  <!-- DM Sans: clean, readable body font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- ── Stylesheets ──────────────────────────────────────────────────── -->
  <!-- Load order matters: variables → base → components → layout → pages -->
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/pages.css" />
  <link rel="stylesheet" href="/css/animations.css" />

  <!-- ── Favicon ──────────────────────────────────────────────────────── -->
  <link rel="icon" href="https://i.postimg.cc/2j9Q4p59/favicon-16x16.png" type="image/png" sizes="16x16" />
  <link rel="shortcut icon" href="https://i.postimg.cc/2j9Q4p59/favicon-16x16.png" type="image/png" />
</head>
<body>

  <!-- ── Navigation Header ─────────────────────────────────────────────── -->
  {{> header}}

  <!-- ── Page Content ──────────────────────────────────────────────────── -->
  <main id="main-content">
    {{{body}}}
  </main>

  <!-- ── Footer ────────────────────────────────────────────────────────── -->
  {{> footer}}

  <!-- ── Theme Toggle Script ───────────────────────────────────────────── -->
  <!-- Loaded first so there's no flash of wrong theme on page load -->
  <script src="/js/theme.js"></script>

  <!-- ── Page Interaction Scripts ──────────────────────────────────────── -->
  <script src="/js/main.js"></script>

</body>
</html>
