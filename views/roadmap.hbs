{{!--
  views/roadmap.hbs — Public Feature Roadmap
  Data comes from roadmap.json via routes/roadmap.js
  To update: edit roadmap.json and push to GitHub. No code changes needed.
--}}

<!-- ── Page Hero ──────────────────────────────────────────────────────────── -->
<section class="page-hero">
  <div class="container page-hero-inner">
    <span class="section-eyebrow">Roadmap</span>
    <h1>What's coming to Soren</h1>
    <p>A transparent look at what we're building next. Updated as features ship.</p>
  </div>
</section>

<!-- ── Stats Bar ──────────────────────────────────────────────────────────── -->
<section class="section" style="padding-block:var(--space-8);">
  <div class="container">
    <div class="stats-bar reveal">

      <div class="stat-item">
        <div class="stat-value">{{totalFeatures}}</div>
        <div class="stat-label">Features Planned</div>
      </div>

      <div class="stat-item">
        <div class="stat-value" style="color:var(--color-accent);">{{inProgressCount}}</div>
        <div class="stat-label">In Progress</div>
      </div>

      <div class="stat-item">
        <div class="stat-value" style="color:#57f287;">{{completeCount}}</div>
        <div class="stat-label">Shipped</div>
      </div>

      <div class="stat-item">
        <div class="stat-value" style="color:var(--color-text-muted);">{{plannedCount}}</div>
        <div class="stat-label">Up Next</div>
      </div>

    </div>
  </div>
</section>

<!-- ── v4.6 Features ──────────────────────────────────────────────────────── -->
{{#if v46}}
<section class="section section--dark">
  <div class="container">

    <div class="section-header reveal">
      <span class="section-eyebrow">Next Release</span>
      <h2>v4.6 — Quick Wins</h2>
      <p>Smaller, high-impact features that are close to ready and address the most common requests.</p>
    </div>

    <div class="roadmap-grid">
      {{#each v46}}
        {{> roadmap-card}}
      {{/each}}
    </div>

  </div>
</section>
{{/if}}

<!-- ── v5.0 Features ──────────────────────────────────────────────────────── -->
{{#if v50}}
<section class="section">
  <div class="container">

    <div class="section-header reveal">
      <span class="section-eyebrow">Major Release</span>
      <h2>v5.0 — The Big Update</h2>
      <p>Deeper features that require more architecture work. These define the next era of Soren.</p>
    </div>

    <div class="roadmap-grid">
      {{#each v50}}
        {{> roadmap-card}}
      {{/each}}
    </div>

  </div>
</section>
{{/if}}

<!-- ── Footer CTA ─────────────────────────────────────────────────────────── -->
<section class="section section--dark">
  <div class="container">
    <div class="cta-section reveal">
      <div class="cta-inner">
        <h2>Have a feature idea?</h2>
        <p>Join the Discord and let us know what you'd like to see. Community feedback shapes the roadmap.</p>
        <div style="display:flex;gap:var(--space-4);flex-wrap:wrap;justify-content:center;">
          <a href="{{discordServer}}" class="btn btn--primary" target="_blank" rel="noopener">Join the Discord</a>
          <a href="/features" class="btn btn--secondary">See Current Features →</a>
        </div>
      </div>
    </div>
  </div>
</section>