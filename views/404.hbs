{{!-- views/404.hbs — Not Found page --}}
<div class="container">
  <div class="page-404">
    <div class="error-code">404</div>
    <h2>Page not found</h2>
    <p style="text-align:center;margin-inline:auto;">
      Whatever you were looking for isn't here. Maybe it moved, maybe it never existed.
    </p>
    <div style="display:flex;gap:var(--space-4);flex-wrap:wrap;justify-content:center;">
      <a href="/" class="btn btn--primary">Go Home</a>
      <a href="/docs" class="btn btn--secondary">Docs →</a>
    </div>
  </div>
</div>
