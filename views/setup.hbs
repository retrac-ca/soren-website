{{!--
  views/setup.hbs — Getting Started / Setup Guide
  Data comes from routes/setup.js and config.js
--}}

<!-- ── Page Hero ──────────────────────────────────────────────────────────── -->
<section class="page-hero">
  <div class="container page-hero-inner">
    <span class="section-eyebrow">Getting Started</span>
    <h1>Set up Soren in minutes</h1>
    <p>Everything you need to go from zero to a fully working events system in your Discord server.</p>
  </div>
</section>

<!-- ── Prerequisites ─────────────────────────────────────────────────────── -->
<section class="section--sm section">
  <div class="container" style="max-width:860px;">

    <div class="callout callout--info reveal" style="margin-bottom:var(--space-8);">
      <span>ℹ️</span>
      <span>
        You'll need <strong>Manage Server</strong> permission (or be the server owner) to add bots and run setup commands.
      </span>
    </div>

    <div class="setup-steps">

      <!-- ── Step 1: Add the bot ─────────────────────────────────────────── -->
      <div class="setup-step reveal">
        <div class="step-number">1</div>
        <div class="setup-step-content">
          <h3>Add Soren to your Discord server</h3>
          <p>
            Click the invite link below. You'll be asked to select a server and approve the required permissions.
            Soren needs: <strong>Send Messages</strong>, <strong>Embed Links</strong>,
            <strong>Read Message History</strong>, and <strong>Mention Everyone</strong>
            (for pinging notify roles during reminders).
          </p>
          <a href="{{inviteUrl}}" class="btn btn--primary" target="_blank" rel="noopener">
            ➕ Add Soren to Discord
          </a>
        </div>
      </div>

      <!-- ── Step 2: /setup ─────────────────────────────────────────────── -->
      <div class="setup-step reveal">
        <div class="step-number">2</div>
        <div class="setup-step-content">
          <h3>Run <code>/setup</code> in your server</h3>
          <p>
            In any text channel, type <code>/setup</code> and pick the role whose members should be able to
            create, edit, and delete events. This is your <strong>Event Creator</strong> role —
            it can be any existing role, or create a new one first.
          </p>
          <p style="margin-top:var(--space-3);">
            Server administrators always have full access regardless of role assignment.
          </p>
        </div>
      </div>

      <!-- ── Step 3: /embedcolor ─────────────────────────────────────────── -->
      <div class="setup-step reveal">
        <div class="step-number">3</div>
        <div class="setup-step-content">
          <h3>Customize your embed color (optional)</h3>
          <p>
            Run <code>/embedcolor</code> to choose the accent color for all event embeds on your server.
            Free servers get 3 colors (Blue, Red, Green). Premium servers unlock 10 colors including Gold, Purple, Cyan, and Orange.
          </p>
        </div>
      </div>

      <!-- ── Step 4: Create first event ─────────────────────────────────── -->
      <div class="setup-step reveal">
        <div class="step-number">4</div>
        <div class="setup-step-content">
          <h3>Create your first event with <code>/newevent</code></h3>
          <p>
            Type <code>/newevent</code> and fill in the fields as Discord autocompletes them.
            Only three fields are required — everything else is optional:
          </p>
          <div class="callout callout--info" style="margin-top:var(--space-4);margin-bottom:var(--space-4);">
            <span>💡</span>
            <span>
              <strong>Example:</strong>
              <code>/newevent channel:#events title:Weekly Raid Night start:Friday 9pm timezone:America/New_York recurrence:Weekly role:@Members reminder:30</code>
            </span>
          </div>
          <table class="comparison-table" style="margin-top:var(--space-4);">
            <thead>
              <tr>
                <th style="text-align:left;">Field</th>
                <th style="text-align:left;">Required</th>
                <th style="text-align:left;">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><code>channel</code></td><td>✅ Yes</td><td>The channel where the event post will appear</td></tr>
              <tr><td><code>title</code></td><td>✅ Yes</td><td>The name of your event</td></tr>
              <tr><td><code>start</code></td><td>✅ Yes</td><td>Start time — natural language like <code>Friday 9pm</code> or <code>July 4 8pm</code></td></tr>
              <tr><td><code>timezone</code></td><td>Optional</td><td>Autocompletes from a curated list, then falls back to all IANA timezones</td></tr>
              <tr><td><code>recurrence</code></td><td>Optional</td><td>Single, Daily, Weekly, Bi-Weekly, Bi-Monthly, Monthly, or Custom — searchable autocomplete</td></tr>
              <tr><td><code>role</code></td><td>Optional</td><td>The role to ping for reminders — native Discord @mention picker</td></tr>
              <tr><td><code>reminder</code></td><td>Optional</td><td>Minutes before the event to send the reminder (e.g. <code>30</code> for 30 minutes)</td></tr>
              <tr><td><code>end</code></td><td>Optional</td><td>End time for the event</td></tr>
              <tr><td><code>description</code></td><td>Optional</td><td>Additional details shown in the event embed</td></tr>
              <tr><td><code>max_rsvp</code></td><td>Optional</td><td>Cap the number of accepted RSVPs for the event</td></tr>
            </tbody>
          </table>
          <div class="callout callout--success" style="margin-top:var(--space-5);">
            <span>✅</span>
            <span>
              <strong>Flexible date input:</strong> The <code>start</code> and <code>end</code> fields accept natural language like
              <code>July 4 8pm</code>, <code>next Friday 9pm</code>, <code>tomorrow 8pm</code>,
              or the strict format <code>2026-07-04 20:00</code>.
            </span>
          </div>
        </div>
      </div>

      <!-- ── Step 5: Useful commands ────────────────────────────────────── -->
      <div class="setup-step reveal">
        <div class="step-number">5</div>
        <div class="setup-step-content">
          <h3>Useful commands to know</h3>
          <p>Once your first event is live, here are a few commands your members will find handy:</p>
          <ul style="margin-top:var(--space-3);display:flex;flex-direction:column;gap:var(--space-2);">
            <li><code>/listevents</code> — View all upcoming events in the server, paginated.</li>
            <li><code>/myevents</code> — See every event you've RSVPed to (accepted or tentative).</li>
            <li><code>/eventbuttons</code> — Toggle the Tentative button or rename RSVP labels <strong>(Premium)</strong>.</li>
            <li><code>/premium</code> — View the free vs. premium feature comparison directly in Discord.</li>
          </ul>
          <div class="callout callout--info" style="margin-top:var(--space-4);">
            <span>⭐</span>
            <span>
              <strong>Premium reminder tip:</strong> Free servers can notify 1 role per event reminder.
              Upgrade to Premium to notify up to 3 roles — great for servers with multiple member groups.
            </span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── Google Calendar Setup (optional) ──────────────────────────────────── -->
<section class="section section--dark" id="google-calendar">
  <div class="container" style="max-width:860px;">
    <div class="reveal" style="margin-bottom:var(--space-10);">
      <span class="section-eyebrow">Optional</span>
      <h2>Google Calendar Integration</h2>
      <p style="font-size:var(--text-lg);">
        Connect your Google Calendars directly to Discord. Soren handles the entire authorization
        process — no setup outside of Discord required.
      </p>
    </div>

    <div class="grid-2 reveal" style="margin-bottom:var(--space-10);">
      <div class="card">
        <h4>📥 G-Cal Integrations (<code>/gcalint</code>)</h4>
        <p style="font-size:var(--text-sm);margin-top:var(--space-3);">
          Connect multiple Google Calendars. Each one posts a weekly digest summary into its own Discord channel.
          Great for syncing a shared team or community calendar. Free tier: up to 2 integrations; Premium: up to 5.
        </p>
      </div>
    </div>

    <div class="setup-steps">

      <div class="setup-step reveal">
        <div class="step-number">1</div>
        <div class="setup-step-content">
          <h3>Run <code>/gcalint add</code> in Discord</h3>
          <p>
            In your server, run <code>/gcalint add</code>. Soren's built-in wizard will walk you through the rest —
            just follow the prompts it sends you.
          </p>
        </div>
      </div>

      <div class="setup-step reveal">
        <div class="step-number">2</div>
        <div class="setup-step-content">
          <h3>Authorize with Google</h3>
          <p>
            Soren will send you an authorization link. Click it and sign in with the Google account
            that owns the calendar you want to connect. After approving access, you'll be redirected
            to the Soren website where your authorization code will be displayed automatically.
          </p>
        </div>
      </div>

      <div class="setup-step reveal">
        <div class="step-number">3</div>
        <div class="setup-step-content">
          <h3>Complete the connection in Discord</h3>
          <p>
            Copy the code shown on the Soren website and paste it into <code>/gcalint verify</code> in Discord.
            A calendar picker will appear — select which calendar to connect and you're done.
          </p>
          <div class="callout callout--success" style="margin-top:var(--space-4);">
            <span>✅</span>
            <span>
              Once connected, Soren will automatically post weekly digest summaries to your chosen channel
              and fire reminders before upcoming events.
            </span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── Next steps ─────────────────────────────────────────────────────────── -->
<section class="section section--dark">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">What's next?</span>
      <h2>You're all set — now explore</h2>
    </div>
    <div class="grid-3 reveal">
      <a href="/docs" class="card card-hover" style="text-decoration:none;">
        <div class="feature-icon">📖</div>
        <h4>Full Command Reference</h4>
        <p>Every slash command, who can use it, and what it does.</p>
      </a>
      <a href="/features#pricing" class="card card-hover" style="text-decoration:none;">
        <div class="feature-icon">⭐</div>
        <h4>Upgrade to Premium</h4>
        <p>Unlock more events, RSVPs, colors, and G-Cal integrations for a one-time price.</p>
      </a>
      <a href="{{discordServer}}" class="card card-hover" style="text-decoration:none;" target="_blank" rel="noopener">
        <div class="feature-icon">💬</div>
        <h4>Join the Beta</h4>
        <p>Get early access, report bugs, and help shape Soren's future in the support Discord.</p>
      </a>
    </div>
  </div>
</section>